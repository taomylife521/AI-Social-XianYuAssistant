# ============================================================
# XianYuAssistant 配置文件
# 直接修改下面的值即可, 修改后重启生效: docker compose up -d
# ============================================================

# --- 端口配置 ---
APP_PORT=12400                            # 应用服务端口
CHROMA_PORT=8321                          # Chroma向量数据库端口

# --- 数据存储路径 (物理机路径) ---
SQLITE_DATA_PATH=./data/sqlite            # SQLite数据库文件路径
LOGS_PATH=./data/logs                     # 应用日志路径
CHROMA_DATA_PATH=./data/chroma            # Chroma向量数据库路径

# --- API配置 ---
ALI_API_KEY=                              # 阿里云API Key (AI功能必需, 留空则不启用)
CHROMA_AUTH_TOKEN=xianyu-chroma-token     # Chroma认证Token
